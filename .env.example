# Phase 2 reads this key from the backend environment for both step generation
# and selector recovery.
ANTHROPIC_API_KEY=

# Optional: override the Claude model used by backend/step_generator.py and
# backend/ai_recovery.py.
ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional: set to false when you want to watch the browser during debugging.
PLAYWRIGHT_HEADLESS=true
